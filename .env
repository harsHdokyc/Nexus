# ===========================================
# OAUTH CREDENTIALS
# ===========================================
# These are used in Edge Functions for platform OAuth
# Configure these when setting up OAuth integrations

# Gmail / Google OAuth
# Get from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_REDIRECT_URI=http://localhost:6173/api/auth/callback/google

# Slack OAuth  
# Get from: https://api.slack.com/apps
# SLACK_CLIENT_ID=your_slack_client_id
# SLACK_CLIENT_SECRET=your_slack_client_secret
# SLACK_REDIRECT_URI=http://localhost:6173/api/auth/callback/slack

# Twitter/X OAuth 2.0
# Get from: https://developer.twitter.com/en/portal/dashboard
# TWITTER_CLIENT_ID=your_twitter_client_id
# TWITTER_CLIENT_SECRET=your_twitter_client_secret
# TWITTER_REDIRECT_URI=http://localhost:6173/api/auth/callback/twitter

# Microsoft Teams OAuth
# Get from: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# MICROSOFT_CLIENT_ID=your_microsoft_client_id
# MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
# MICROSOFT_REDIRECT_URI=http://localhost:6173/api/auth/callback/microsoft

# ===========================================
# CACHING (Optional)
# ===========================================
# Upstash Redis for caching
# Get from: https://console.upstash.com/

# UPSTASH_REDIS_URL=your_upstash_redis_url
# UPSTASH_REDIS_TOKEN=your_upstash_redis_token

# ===========================================
# ANALYTICS & MONITORING (Optional)
# ===========================================

# SENTRY_DSN=your_sentry_dsn

# ===========================================
# ENCRYPTION
# ===========================================
# Generate with: openssl rand -base64 32

# ENCRYPTION_KEY=your_32_byte_encryption_key